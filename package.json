{
  "name": "promptgist",
  "version": "0.0.0",
  "author": {
    "name": "Dominik Hladík",
    "email": "dominik.hladik@seznam.cz",
    "url": "https://github.com/Celtian"
  },
  "scripts": {
    "ng": "ng",
    "start": "yarn start:portal",
    "start:portal": "ng serve --project portal",
    "start:design": "ng serve --project design",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "prepare": "husky",
    "postinstall": "yarn create-version",
    "create-version": "npx package-version-info -o generated/version-info.ts",
    "check-circular-dependencies": "madge --circular --ts-config tsconfig.json ./projects/*/src/public-api.ts"
  },
  "private": true,
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/router": "^21.2.13",
    "ngx-app-version": "^2.2.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.4.0",
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.13",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-angular": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "angular-eslint": "21.4.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "ng-packagr": "^21.2.3",
    "package-version-info": "^0.0.6",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=24 <26",
    "npm": "please-use-yarn"
  }
}
